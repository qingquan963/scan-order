# Phase 1: PostgreSQL 连接（生产环境）
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://scanorder:scanorder@39.104.107.136:5432/scanorder

# 原有配置
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
API_V1_PREFIX=/api/v1
FRONTEND_PUBLIC_URL=http://localhost:3000

# Phase 3A: 微信 OAuth（如已配置则填入）
# WX_APP_ID=your_wx_app_id
# WX_APP_SECRET=your_wx_app_secret
# WX_CALLBACK_URL=https://yourdomain.com/api/v1/wx/auth/callback

# Phase 3A: Cookie（如在生产环境使用）
# COOKIE_DOMAIN=yourdomain.com
# COOKIE_SECURE=true
# COOKIE_HTTPONLY=true
# COOKIE_SAMESITE=lax

# Phase Kitchen: 后厨屏配置
KITCHEN_PIN=1234
KITCHEN_TOKEN_TTL=28800
